        "#imagine you are a shop owner tracking sales of three products throughout the day.at the end of the day ,you want to calculate the total\n",
        "#sales from these products .product quantity and prices are given below in the next code cell,\n",
        "#write a program that\n",
        "#calculates the total sales for each product\n",
        "#2.summarizes the total sales for the day\n",
        "#3.print the summary in a formatted manner\n",
        "# Product quantities\n",
        "qty1 = 20\n",
        "qty2 = 35\n",
        "qty3 = 240\n",
        "\n",
        "# Product prices\n",
        "price1 = 15*20\n",
        "price2 = 10*35\n",
        "price3 = 20*240\n",
        "\n",
        "# Total sales for each product\n",
        "sales1 = qty1 * price1\n",
        "sales2 = qty2 * price2\n",
        "sales3 = qty3 * price3\n",
        "\n",
        "# Total sales for the day\n",
        "total_sales = sales1 + sales2 + sales3\n",
        "\n",
        "# Formatted output\n",
        "print(\"----- Daily Sales Summary -----\")\n",
        "print(\"Product 1 Sales =\", sales1)\n",
        "print(\"Product 2 Sales =\", sales2)\n",
        "print(\"Product 3 Sales =\", sales3)\n",
        "print(\"-------------------------------\")\n",
        "print(\"Total Sales for the Day =\", total_sales)"
      ],
